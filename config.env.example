# 复制为 config.env 并 chmod 600 config.env
# MOCK_MODE=true 时不连真实服务器，仅演示 12 步流水线动画
# 当 TEST_PASSWORD / PROD_PASSWORD 仍为 CHANGE_ME 时也会自动进入演示模式

MOCK_MODE=true
# 演示模式每步停顿秒数（可调快/调慢）
MOCK_STEP_DELAY_SEC=1.2

# --- 测试机 25（触发备份）---
TEST_HOST=43.242.200.25
TEST_PORT=58753
TEST_USER=root
TEST_PASSWORD=CHANGE_ME
TEST_BACKUP_SCRIPT=/www/osh-backup-tools/osh-backup-25.sh
TEST_BACKUP_LOG_DIR=/www/osh-backup-tools/logs
TEST_BACKUP_LOCK=/www/osh-backup-tools/.backup.lock

# --- 生产机 149（切流 / SQL / 同步）---
# PROD_EXEC_MODE:
#   auto  — 默认：本机存在 TRAFFIC_SWITCH_SCRIPT 或 PROD_HOST 为本机时用 bash 直连；否则 sshpass SSH（本地开发）
#   local — 强制本机 bash 执行（控制台跑在 149 上时用，无需 sshpass）
#   ssh   — 强制 sshpass 远程 SSH
PROD_EXEC_MODE=auto
PROD_HOST=149.88.92.159
PROD_PORT=16328
PROD_USER=root
PROD_PASSWORD=CHANGE_ME
# --- 149 部署目标：绿环境（不更新蓝 /opt/osh）---
PROD_DEPLOY_TARGET=green
PROD_CODE_SYNC_SCRIPT=/opt/osh-deploy-tools/osh-green-code-sync.sh
PROD_CODE_SYNC_LOG=/opt/osh-deploy-tools/logs/green-code-sync.log
# 必须为 false：prod-release 会改蓝项目，红线禁止
PROD_USE_RELEASE=false
PROD_NGINX_PORT=28080
PROD_BACKEND_PORT=28081
PROD_NACOS_PORT=28848

# --- 编排器 ---
BIND_HOST=127.0.0.1
BIND_PORT=8765
# 可选：简单鉴权 token，留空则仅本机访问
API_TOKEN=
POLL_INTERVAL_SEC=10
BACKUP_TIMEOUT_SEC=7200
PROD_RELEASE_TIMEOUT_SEC=3600

# --- Go 发布控制面 (P1, cmd/server) ---
# 与上面 PROD_* / BIND_* 共用；也可单独指定 LISTEN_ADDR
SQLITE_PATH=./data/platform.db
TRAFFIC_SWITCH_SCRIPT=/opt/osh-green/005-scripts/osh-traffic-switch.sh
STANDBY_SYNC_SCRIPT=/opt/osh-green/005-scripts/osh-prod-standby-sync.sh
# GHA 只上传代码；patch 端口/Nacos/前端 URL 由该脚本在 149 上执行（发布控制台 GHA 完成后自动调用）
SLOT_POSTDEPLOY_SCRIPT=/opt/osh-green/005-scripts/osh-slot-postdeploy.sh

# --- 蓝环境 MySQL SQL（仅 osh-mysql，生产在绿时操作待命蓝库）---
BLUE_MYSQL_CONTAINER=osh-mysql
BLUE_MYSQL_DATABASE=backstage
BLUE_MYSQL_ROOT_PASSWORD=CHANGE_ME
BLUE_CODE_SYNC_SCRIPT=/opt/osh-deploy-tools/osh-prod-code-sync.sh
ANALYZER_URL=http://127.0.0.1:8766
BOSS_REVIEWER=juege
SUPER_ADMIN_USER=juege
JUEGE_PASSWORD=CHANGE_ME
# 其他普通用户：用户名:密码:显示名（逗号分隔，可多个）
# AUTH_USERS=zhangsan:pass123:张三,lisi:pass456:李四
# GitHub：审批通过后触发 deploy-prod.yml（149 绿/蓝环境；deploy-qa.yml 为 25 测试自动部署，勿混用）
GITHUB_TOKEN=
GITHUB_BACKEND_REPO=juege-osh/osh-backend
GITHUB_FRONTEND_REPO=juege-osh/osh-frontend
# 前后端分支可不同：backend=release/*  frontend=prod/*
# dispatch_ref 默认与 git_ref 相同（workflow 文件须在该分支上）
GITHUB_BACKEND_GIT_REF=release/20260708
GITHUB_FRONTEND_GIT_REF=prod/20260708
# 仅当 workflow 与构建分支不同时才单独设置：
# GITHUB_BACKEND_DISPATCH_REF=
# GITHUB_FRONTEND_DISPATCH_REF=
# 兼容旧配置（未设上面两项时回退）
GITHUB_DISPATCH_REF=

# --- 绿环境 MySQL SQL 迁移（仅 osh-g-mysql）---
GREEN_MYSQL_CONTAINER=osh-g-mysql
GREEN_MYSQL_DATABASE=backstage
GREEN_MYSQL_ROOT_PASSWORD=CHANGE_ME
MIGRATIONS_DIR=./migrations
