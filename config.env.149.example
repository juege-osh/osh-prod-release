# 149 config template — copied to config.env on first deploy only (existing config.env is never overwritten)
MOCK_MODE=false
PROD_EXEC_MODE=local

PROD_HOST=127.0.0.1
PROD_PORT=16328
PROD_USER=root
PROD_PASSWORD=

BIND_HOST=0.0.0.0
BIND_PORT=8765
LISTEN_ADDR=0.0.0.0:8765

DATA_DIR=/opt/osh-prod-release/data
SQLITE_PATH=/opt/osh-prod-release/data/platform.db
MIGRATIONS_DIR=/opt/osh-prod-release/migrations

TRAFFIC_SWITCH_SCRIPT=/opt/osh-green/005-scripts/osh-traffic-switch.sh
STANDBY_SYNC_SCRIPT=/opt/osh-green/005-scripts/osh-prod-standby-sync.sh
GREEN_CODE_SYNC_SCRIPT=/opt/osh-deploy-tools/osh-green-code-sync.sh
BLUE_CODE_SYNC_SCRIPT=/opt/osh-deploy-tools/osh-prod-code-sync.sh
COMPONENT_CHANGE_SCRIPT=/opt/osh-prod-release/scripts/osh-component-change.sh
BLUE_TO_GREEN_ALL_SYNC_SCRIPT=/opt/osh-prod-release/scripts/run-incremental-blue-to-green-all-components.sh

GREEN_MYSQL_CONTAINER=osh-g-mysql
GREEN_MYSQL_DATABASE=backstage
GREEN_MYSQL_ROOT_PASSWORD=CHANGE_ME

BLUE_MYSQL_CONTAINER=osh-mysql
BLUE_MYSQL_DATABASE=backstage
BLUE_MYSQL_ROOT_PASSWORD=CHANGE_ME

ANALYZER_URL=http://127.0.0.1:8766
BOSS_REVIEWER=juege
SUPER_ADMIN_USER=juege
JUEGE_PASSWORD=CHANGE_ME
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

GITHUB_TOKEN=
GITHUB_BACKEND_REPO=juege-osh/osh-backend
GITHUB_FRONTEND_REPO=juege-osh/osh-frontend
GITHUB_BACKEND_GIT_REF=release/20260708
GITHUB_FRONTEND_GIT_REF=release/20260708
